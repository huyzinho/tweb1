<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>TWeb Admin Dashboard</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      background: #0b0d13;
      color: #e2e8f0;
      min-height: 100vh;
      line-height: 1.5;
    }

    /* Header styling */
    .header {
      background: rgba(15, 23, 42, 0.85);
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
      padding: 16px 32px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      backdrop-filter: blur(12px);
      position: sticky;
      top: 0;
      z-index: 100;
    }
    .header h1 {
      font-size: 20px;
      font-weight: 700;
      color: #fff;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .header h1 span {
      background: linear-gradient(135deg, #f9752d, #ff5722);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .header-actions { display: flex; align-items: center; gap: 14px; }
    .uptime {
      font-size: 13px;
      font-weight: 500;
      color: #94a3b8;
      padding: 6px 14px;
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 8px;
    }
    .btn-logout {
      padding: 8px 18px;
      background: rgba(239, 68, 68, 0.1);
      color: #f87171;
      border: 1px solid rgba(239, 68, 68, 0.25);
      border-radius: 8px;
      text-decoration: none;
      font-size: 13px;
      font-weight: 600;
      transition: all 0.2s ease;
    }
    .btn-logout:hover {
      background: rgba(239, 68, 68, 0.2);
      border-color: rgba(239, 68, 68, 0.4);
      box-shadow: 0 0 12px rgba(239, 68, 68, 0.15);
    }

    /* Layout structure */
    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 32px 24px;
    }

    /* Stats summary */
    .stats-row {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
      margin-bottom: 32px;
    }
    .stat-card {
      background: rgba(30, 41, 59, 0.4);
      border: 1px solid rgba(255, 255, 255, 0.05);
      border-radius: 16px;
      padding: 24px;
      text-align: center;
      backdrop-filter: blur(8px);
      box-shadow: 0 4px 20px rgba(0,0,0,0.15);
    }
    .stat-value {
      font-size: 32px;
      font-weight: 800;
      color: #fff;
    }
    .stat-label {
      font-size: 13px;
      color: #94a3b8;
      margin-top: 4px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    /* Modern Forms and Cards */
    .card {
      background: rgba(30, 41, 59, 0.35);
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 16px;
      padding: 30px;
      margin-bottom: 32px;
      backdrop-filter: blur(8px);
      box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }
    .card-title {
      font-size: 16px;
      font-weight: 700;
      color: #fff;
      margin-bottom: 24px;
      display: flex;
      align-items: center;
      gap: 10px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
      padding-bottom: 12px;
    }
    .card-title .icon {
      font-size: 18px;
    }

    /* Forms grid layouts */
    .form-grid-3 {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }
    .form-grid-2 {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }
    .form-item {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    .form-item label {
      font-size: 12px;
      color: #94a3b8;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .form-item input {
      width: 100%;
      padding: 12px 16px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 8px;
      background: rgba(15, 23, 42, 0.6);
      color: #fff;
      font-size: 14px;
      outline: none;
      transition: all 0.2s ease;
    }
    .form-item input:focus {
      border-color: #f9752d;
      background: rgba(15, 23, 42, 0.8);
      box-shadow: 0 0 0 3px rgba(249, 117, 45, 0.15);
    }
    .domain-status {
      font-size: 12px;
      margin-top: 4px;
      color: #64748b;
      word-break: break-all;
    }
    .domain-status.active { color: #10b981; font-weight: 500; }
    .domain-status.empty { color: #ef4444; }

    .btn-submit {
      margin-top: 24px;
      padding: 12px 36px;
      border: none;
      border-radius: 8px;
      background: linear-gradient(135deg, #f9752d, #ff5722);
      color: #fff;
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.25s ease;
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }
    .btn-submit:hover {
      transform: translateY(-1px);
      box-shadow: 0 4px 14px rgba(249, 117, 45, 0.4);
    }
    .btn-submit:disabled {
      opacity: 0.5;
      cursor: not-allowed;
      transform: none;
    }
    .action-msg {
      display: inline-block;
      margin-left: 14px;
      font-size: 13px;
      color: #10b981;
      opacity: 0;
      transition: opacity 0.3s ease;
      font-weight: 600;
    }
    .action-msg.show { opacity: 1; }

    /* Tables */
    .table-container {
      overflow-x: auto;
    }
    .log-table {
      width: 100%;
      border-collapse: collapse;
      text-align: left;
    }
    .log-table th {
      font-size: 11px;
      color: #94a3b8;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      padding: 12px 16px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      font-weight: 700;
    }
    .log-table td {
      padding: 14px 16px;
      font-size: 13.5px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.04);
      color: #cbd5e1;
    }
    .log-table tr:hover td {
      background: rgba(255, 255, 255, 0.02);
      color: #fff;
    }
    .badge {
      display: inline-block;
      padding: 4px 10px;
      border-radius: 6px;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .badge-register {
      background: rgba(16, 185, 129, 0.12);
      color: #34d399;
      border: 1px solid rgba(16, 185, 129, 0.2);
    }
    .badge-login {
      background: rgba(59, 130, 246, 0.12);
      color: #60a5fa;
      border: 1px solid rgba(59, 130, 246, 0.2);
    }
    .empty-logs {
      text-align: center;
      padding: 48px;
      color: #64748b;
      font-size: 14px;
    }

    .card-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 24px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
      padding-bottom: 12px;
    }
    .card-header .card-title {
      border: none;
      margin-bottom: 0;
      padding-bottom: 0;
    }
    .btn-refresh {
      padding: 6px 14px;
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 8px;
      color: #cbd5e1;
      font-size: 12px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
    }
    .btn-refresh:hover {
      background: rgba(255, 255, 255, 0.08);
      color: #fff;
    }

    @media (max-width: 900px) {
      .form-grid-3, .form-grid-2 { grid-template-columns: 1fr; }
      .stats-row { grid-template-columns: 1fr; }
      .container { padding: 16px; }
    }
  </style>
</head>
<body>
  <!-- Header -->
  <div class="header">
    <h1>⚡ <span>TWeb</span> Quản Trị Hệ Thống</h1>
    <div class="header-actions">
      <span class="uptime" id="uptimeDisplay">Uptime: --</span>
      <a href="/admin/logout" class="btn-logout">Đăng xuất</a>
    </div>
  </div>

  <div class="container">
    <!-- Stats Row -->
    <div class="stats-row">
      <div class="stat-card">
        <div class="stat-value" id="totalLogs">0</div>
        <div class="stat-label">Tổng hoạt động</div>
      </div>
      <div class="stat-card">
        <div class="stat-value" id="totalRegisters">0</div>
        <div class="stat-label">Đăng ký</div>
      </div>
      <div class="stat-card">
        <div class="stat-value" id="totalLogins">0</div>
        <div class="stat-label">Đăng nhập</div>
      </div>
    </div>

    <!-- Domain Settings Card -->
    <div class="card">
      <div class="card-title"><span class="icon">🌐</span> Cài đặt tên miền chuyển hướng</div>
      <form id="domainForm">
        <div class="form-grid-3">
          <div class="form-item">
            <label>Tên miền chuyển hướng (Redirect)</label>
            <input type="text" id="redirectDomain" value="<%= domainConfig.redirectDomain %>" placeholder="example.com" />
            <div class="domain-status <%= domainConfig.redirectDomain ? 'active' : 'empty' %>" id="statusRedirect">
              <%= domainConfig.redirectDomain || 'Chưa thiết lập' %>
            </div>
          </div>
          <div class="form-item">
            <label>Tên miền đăng nhập (Login)</label>
            <input type="text" id="loginDomain" value="<%= domainConfig.loginDomain %>" placeholder="login.example.com" />
            <div class="domain-status <%= domainConfig.loginDomain ? 'active' : 'empty' %>" id="statusLogin">
              <%= domainConfig.loginDomain || 'Chưa thiết lập' %>
            </div>
          </div>
          <div class="form-item">
            <label>Tên miền đăng ký (Register)</label>
            <input type="text" id="regDomain" value="<%= domainConfig.regDomain %>" placeholder="reg.example.com" />
            <div class="domain-status <%= domainConfig.regDomain ? 'active' : 'empty' %>" id="statusReg">
              <%= domainConfig.regDomain || 'Chưa thiết lập' %>
            </div>
          </div>
        </div>
        <button type="submit" class="btn-submit" id="btnSaveDomains">💾 Lưu tên miền</button>
        <span class="action-msg" id="saveDomainsMsg">✓ Đã lưu thành công!</span>
      </form>
    </div>

    <!-- System Config Card (.env) -->
    <div class="card">
      <div class="card-title"><span class="icon">⚙️</span> Cấu hình hệ thống (Environment Variables)</div>
      <form id="configForm">
        <div class="form-grid-2">
          <div class="form-item">
            <label>Telegram Bot Token</label>
            <input type="text" id="telegramToken" placeholder="Nhập token bot telegram..." />
          </div>
          <div class="form-item">
            <label>Chat ID Telegram</label>
            <input type="text" id="chatId" placeholder="Nhập chat id nhận tin..." />
          </div>
        </div>
        <div class="form-grid-2" style="margin-top: 20px;">
          <div class="form-item">
            <label>Google Sheet Webhook URL</label>
            <input type="text" id="googleSheetUrl" placeholder="Nhập URL script sheets..." />
          </div>
          <div class="form-item">
            <label>Mật khẩu Quản trị (Admin Password)</label>
            <input type="password" id="adminPassword" placeholder="Nhập mật khẩu admin mới..." />
          </div>
        </div>
        <button type="submit" class="btn-submit" id="btnSaveConfig">⚙️ Lưu cấu hình</button>
        <span class="action-msg" id="saveConfigMsg">✓ Đã áp dụng & lưu cấu hình!</span>
      </form>
    </div>

    <!-- Activity Logs Card -->
    <div class="card">
      <div class="card-header">
        <div class="card-title"><span class="icon">📋</span> Nhật ký hoạt động thu thập</div>
        <button class="btn-refresh" onclick="loadStatus()">🔄 Làm mới</button>
      </div>
      <div class="table-container" id="logContainer">
        <div class="empty-logs">Đang tải dữ liệu...</div>
      </div>
    </div>
  </div>

  <script>
    // ============================================================
    // Submit domains configuration
    // ============================================================
    document.getElementById('domainForm').addEventListener('submit', async function(e) {
      e.preventDefault();
      const btn = document.getElementById('btnSaveDomains');
      const msg = document.getElementById('saveDomainsMsg');
      btn.disabled = true;
      btn.textContent = '⏳ Đang lưu...';

      try {
        const res = await fetch('/admin/api/domains', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            redirectDomain: document.getElementById('redirectDomain').value,
            loginDomain: document.getElementById('loginDomain').value,
            regDomain: document.getElementById('regDomain').value,
          })
        });
        const data = await res.json();
        if (data.success) {
          msg.classList.add('show');
          updateDomainStatus(data.domainConfig);
          setTimeout(() => msg.classList.remove('show'), 3000);
        }
      } catch (err) {
        alert('Lỗi khi lưu tên miền: ' + err.message);
      }

      btn.disabled = false;
      btn.textContent = '💾 Lưu tên miền';
    });

    // ============================================================
    // Submit environment system configuration
    // ============================================================
    document.getElementById('configForm').addEventListener('submit', async function(e) {
      e.preventDefault();
      const btn = document.getElementById('btnSaveConfig');
      const msg = document.getElementById('saveConfigMsg');
      btn.disabled = true;
      btn.textContent = '⏳ Đang áp dụng...';

      try {
        const res = await fetch('/admin/api/config', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            TELEGRAM_TOKEN: document.getElementById('telegramToken').value,
            CHAT_ID: document.getElementById('chatId').value,
            GOOGLE_SHEET_URL: document.getElementById('googleSheetUrl').value,
            ADMIN_PASSWORD: document.getElementById('adminPassword').value,
          })
        });
        const data = await res.json();
        if (data.success) {
          msg.classList.add('show');
          setTimeout(() => msg.classList.remove('show'), 3000);
        }
      } catch (err) {
        alert('Lỗi khi lưu cấu hình: ' + err.message);
      }

      btn.disabled = false;
      btn.textContent = '⚙️ Lưu cấu hình';
    });

    // ============================================================
    // Update domain UI fields
    // ============================================================
    function updateDomainStatus(config) {
      ['redirect', 'login', 'reg'].forEach(key => {
        const domainKey = key + 'Domain';
        const el = document.getElementById('status' + key.charAt(0).toUpperCase() + key.slice(1));
        const val = config[domainKey];
        el.textContent = val || 'Chưa thiết lập';
        el.className = 'domain-status ' + (val ? 'active' : 'empty');
      });
    }

    // ============================================================
    // Load current logs & configs
    // ============================================================
    async function loadStatus() {
      try {
        const res = await fetch('/admin/api/status');
        const data = await res.json();

        // Update Uptime
        const secs = Math.floor(data.uptime);
        const h = Math.floor(secs / 3600);
        const m = Math.floor((secs % 3600) / 60);
        const s = secs % 60;
        document.getElementById('uptimeDisplay').textContent =
          'Uptime: ' + h + 'h ' + m + 'm ' + s + 's';

        // Update statistics
        const logs = data.recentLogs || [];
        document.getElementById('totalLogs').textContent = logs.length;
        document.getElementById('totalRegisters').textContent =
          logs.filter(l => l.action === 'register').length;
        document.getElementById('totalLogins').textContent =
          logs.filter(l => l.action === 'login').length;

        // Populate Env Config values once or on refresh
        if (data.env) {
          document.getElementById('telegramToken').value = data.env.TELEGRAM_TOKEN || '';
          document.getElementById('chatId').value = data.env.CHAT_ID || '';
          document.getElementById('googleSheetUrl').value = data.env.GOOGLE_SHEET_URL || '';
          document.getElementById('adminPassword').value = data.env.ADMIN_PASSWORD || '';
        }

        // Render logs table
        const container = document.getElementById('logContainer');
        if (logs.length === 0) {
          container.innerHTML = '<div class="empty-logs">Chưa có hoạt động thu thập nào</div>';
          return;
        }

        let html = '<table class="log-table"><thead><tr>' +
          '<th>Loại hoạt động</th><th>Tên tài khoản / SĐT</th><th>Địa chỉ IP</th><th>Thời gian</th>' +
          '</tr></thead><tbody>';

        logs.slice().reverse().forEach(log => {
          const badge = log.action === 'register'
            ? '<span class="badge badge-register">Đăng ký</span>'
            : '<span class="badge badge-login">Đăng nhập</span>';
          html += '<tr>' +
            '<td>' + badge + '</td>' +
            '<td style="font-family: monospace; font-weight: 600;">' + (log.accountId || log.phone || '-') + '</td>' +
            '<td style="font-family: monospace;">' + (log.ip || '-') + '</td>' +
            '<td>' + (log.time || '-') + '</td>' +
            '</tr>';
        });

        html += '</tbody></table>';
        container.innerHTML = html;
      } catch (err) {
        console.error('Lỗi khi tải dữ liệu trạng thái:', err);
      }
    }

    // Initial load & automatic refresh every 15 seconds
    loadStatus();
    setInterval(loadStatus, 15000);
  </script>
</body>
</html>
