<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>TWeb Admin Login</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      background: radial-gradient(circle at center, #0f172a 0%, #020617 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #f1f5f9;
      overflow: hidden;
      position: relative;
    }

    /* Ambient background glows */
    .glow-1 {
      position: absolute;
      width: 500px;
      height: 500px;
      background: radial-gradient(circle, rgba(249, 117, 45, 0.08) 0%, transparent 70%);
      top: -10%;
      left: -10%;
      z-index: 0;
    }
    .glow-2 {
      position: absolute;
      width: 600px;
      height: 600px;
      background: radial-gradient(circle, rgba(99, 102, 241, 0.08) 0%, transparent 70%);
      bottom: -10%;
      right: -10%;
      z-index: 0;
    }

    .login-container {
      position: relative;
      z-index: 1;
      width: 100%;
      max-width: 420px;
      padding: 20px;
    }

    .login-card {
      background: rgba(30, 41, 59, 0.45);
      backdrop-filter: blur(16px);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 20px;
      padding: 48px 40px;
      box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
      animation: cardFadeIn 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    }

    @keyframes cardFadeIn {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .logo-area {
      text-align: center;
      margin-bottom: 36px;
    }
    .logo-icon {
      font-size: 36px;
      margin-bottom: 12px;
      display: inline-block;
      filter: drop-shadow(0 0 10px rgba(249, 117, 45, 0.3));
    }
    .logo-area h1 {
      color: #fff;
      font-size: 26px;
      font-weight: 800;
      letter-spacing: -0.5px;
    }
    .logo-area h1 span {
      background: linear-gradient(135deg, #f9752d, #ff5722);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .logo-area p.sub {
      color: #94a3b8;
      font-size: 13.5px;
      margin-top: 6px;
      font-weight: 500;
    }

    .form-group {
      margin-bottom: 24px;
      position: relative;
    }
    .form-group label {
      display: block;
      color: #94a3b8;
      font-size: 11.5px;
      margin-bottom: 8px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.75px;
    }
    .form-group input {
      width: 100%;
      padding: 14px 18px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 10px;
      background: rgba(15, 23, 42, 0.6);
      color: #fff;
      font-size: 15px;
      outline: none;
      transition: all 0.25s ease;
    }
    .form-group input:focus {
      border-color: #f9752d;
      background: rgba(15, 23, 42, 0.8);
      box-shadow: 0 0 0 3px rgba(249, 117, 45, 0.15);
    }

    .error-msg {
      background: rgba(239, 68, 68, 0.1);
      border: 1px solid rgba(239, 68, 68, 0.2);
      color: #f87171;
      font-size: 13px;
      font-weight: 600;
      padding: 10px 14px;
      border-radius: 8px;
      text-align: center;
      margin-bottom: 24px;
      animation: shake 0.4s ease;
    }

    @keyframes shake {
      0%, 100% { transform: translateX(0); }
      25% { transform: translateX(-4px); }
      75% { transform: translateX(4px); }
    }

    .btn-login {
      width: 100%;
      padding: 14px;
      border: none;
      border-radius: 10px;
      background: linear-gradient(135deg, #f9752d, #ff5722);
      color: #fff;
      font-size: 15px;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.25s ease;
    }
    .btn-login:hover {
      transform: translateY(-1px);
      box-shadow: 0 6px 20px rgba(249, 117, 45, 0.4);
    }
    .btn-login:active {
      transform: translateY(0);
    }
  </style>
</head>
<body>
  <div class="glow-1"></div>
  <div class="glow-2"></div>

  <div class="login-container">
    <div class="login-card">
      <div class="logo-area">
        <span class="logo-icon">🔐</span>
        <h1><span>TWeb</span> Admin</h1>
        <p class="sub">Vui lòng nhập mật khẩu quản lý</p>
      </div>

      <% if (error) { %>
        <div class="error-msg"><%= error %></div>
      <% } %>

      <form method="POST" action="/admin/login">
        <div class="form-group">
          <label>Mật khẩu hệ thống</label>
          <input type="password" name="password" placeholder="Nhập mật khẩu..." autofocus required />
        </div>
        <button type="submit" class="btn-login">Đăng Nhập</button>
      </form>
    </div>
  </div>
</body>
</html>
